<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->


    <bean id="dept" class="com.coforge.beans.Department">
        <constructor-arg value="1"/>
        <constructor-arg value="Training"/>
        <constructor-arg value="Hyderbad"/>
    </bean>

    <bean id="emp" class="com.coforge.beans.Employee" scope="prototype">
        <constructor-arg value="123"/>
        <constructor-arg value="Suman"/>
        <constructor-arg ref="dept"/>
    </bean>

    <bean id="emp1" class="com.coforge.beans.Employee">
        <constructor-arg value="156"/>
        <constructor-arg value="Ritika"/>
        <constructor-arg ref="dept"/>
    </bean>

</beans>
